# --- Sui zkLogin (Enoki) ---
# Copy this file to .env.local and fill in the values. See ZKLOGIN_SETUP.md.
# All three are NEXT_PUBLIC_* because the zkLogin flow runs in the browser.
# Use the PUBLIC Enoki API key here — never the private/secret one.

NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_ENOKI_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
